<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/navbar') %>
  
  <main class="main-content">
    <div class="container">
      <div class="hero">
        <h1><%= __('home.title') %></h1>
        <p><%= __('home.subtitle') %></p>
        
        <% if (!user) { %>
          <div class="hero-buttons">
            <a href="/register" class="btn btn-secondary"><%= __('home.getStarted') %></a>
            <a href="/login" class="btn" style="background: transparent; border: 2px solid white; color: white;"><%= __('nav.login') %></a>
          </div>
        <% } else { %>
          <div class="hero-buttons">
            <a href="/dashboard" class="btn btn-secondary"><%= __('nav.dashboard') %></a>
          </div>
        <% } %>
      </div>
      
      <div class="features">
        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3><%= __('home.features.secure.title') %></h3>
          <p><%= __('home.features.secure.desc') %></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3><%= __('home.features.easy.title') %></h3>
          <p><%= __('home.features.easy.desc') %></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌐</div>
          <h3><%= __('home.features.oauth.title') %></h3>
          <p><%= __('home.features.oauth.desc') %></p>
        </div>
      </div>
    </div>
  </main>
  
  <%- include('partials/footer') %>
</body>
</html>
