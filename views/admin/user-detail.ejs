<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('../partials/head') %>
  <style>
    .admin-sidebar {
      min-height: calc(100vh - 56px);
      background: #2c3e50;
      color: white;
    }
    .admin-sidebar .nav-link {
      color: rgba(255,255,255,0.8);
      padding: 12px 20px;
      border-left: 3px solid transparent;
    }
    .admin-sidebar .nav-link:hover,
    .admin-sidebar .nav-link.active {
      color: white;
      background: rgba(255,255,255,0.1);
      border-left-color: #3498db;
    }
    .admin-sidebar .nav-link i {
      width: 24px;
      margin-right: 8px;
    }
    .user-avatar-large {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
    }
    .info-row {
      padding: 12px 0;
      border-bottom: 1px solid #eee;
    }
    .info-row:last-child {
      border-bottom: none;
    }
    .info-label {
      color: #6c757d;
      font-weight: 500;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container-fluid">
    <div class="row">
      <!-- 侧边栏 -->
      <div class="col-md-2 px-0">
        <div class="admin-sidebar py-3">
          <div class="px-4 mb-3">
            <h5 class="mb-0">管理后台</h5>
            <small class="text-muted">Admin Panel</small>
          </div>
          <nav class="nav flex-column">
            <a class="nav-link" href="/admin">
              <i class="bi bi-speedometer2"></i> 仪表盘
            </a>
            <a class="nav-link active" href="/admin/users">
              <i class="bi bi-people"></i> 用户管理
            </a>
            <a class="nav-link" href="/admin/stats">
              <i class="bi bi-graph-up"></i> 系统统计
            </a>
            <div class="mt-3 px-4">
              <small class="text-muted">返回</small>
            </div>
            <a class="nav-link" href="/dashboard">
              <i class="bi bi-arrow-left"></i> 用户中心
            </a>
          </nav>
        </div>
      </div>
      
      <!-- 主内容区 -->
      <div class="col-md-10 py-4">
        <div class="container">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">用户详情</h2>
            <a href="/admin/users" class="btn btn-outline-secondary">
              <i class="bi bi-arrow-left"></i> 返回列表
            </a>
          </div>
          
          <%- include('../partials/messages') %>
          
          <div class="row">
            <!-- 左侧：用户基本信息 -->
            <div class="col-md-4">
              <div class="card mb-4">
                <div class="card-body text-center">
                  <img src="<%= targetUser.avatar || '/images/default-avatar.png' %>" 
                       class="user-avatar-large mb-3" alt="头像">
                  <h4 class="mb-1"><%= targetUser.username %></h4>
                  <p class="text-muted mb-3"><%= targetUser.email %></p>
                  
                  <% if (targetUser.role === 'admin') { %>
                    <span class="badge bg-danger fs-6">管理员</span>
                  <% } else if (targetUser.role === 'moderator') { %>
                    <span class="badge bg-info fs-6">版主</span>
                  <% } else { %>
                    <span class="badge bg-secondary fs-6">普通用户</span>
                  <% } %>
                  
                  <% if (targetUser.isActive === false) { %>
                    <span class="badge bg-dark fs-6 ms-2">已禁用</span>
                  <% } %>
                </div>
              </div>
              
              <!-- 快捷操作 -->
              <% if (targetUser.id !== user.id) { %>
                <div class="card">
                  <div class="card-header">
                    <h5 class="mb-0">快捷操作</h5>
                  </div>
                  <div class="card-body">
                    <form method="POST" action="/admin/users/<%= targetUser.id %>/toggle-status" class="mb-2">
                      <button type="submit" class="btn btn-<%= targetUser.isActive !== false ? 'warning' : 'success' %> w-100">
                        <i class="bi bi-<%= targetUser.isActive !== false ? 'pause' : 'play' %>-fill"></i>
                        <%= targetUser.isActive !== false ? '禁用账户' : '启用账户' %>
                      </button>
                    </form>
                    
                    <button type="button" class="btn btn-danger w-100" 
                            onclick="confirmDelete('<%= targetUser.id %>', '<%= targetUser.username %>')">
                      <i class="bi bi-trash"></i> 删除账户
                    </button>
                  </div>
                </div>
              <% } %>
            </div>
            
            <!-- 右侧：详细信息 -->
            <div class="col-md-8">
              <div class="card mb-4">
                <div class="card-header">
                  <h5 class="mb-0">详细信息</h5>
                </div>
                <div class="card-body">
                  <div class="info-row row">
                    <div class="col-md-4 info-label">用户ID</div>
                    <div class="col-md-8"><code><%= targetUser.id %></code></div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">用户名</div>
                    <div class="col-md-8"><%= targetUser.username %></div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">邮箱地址</div>
                    <div class="col-md-8"><%= targetUser.email %></div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">邮箱验证</div>
                    <div class="col-md-8">
                      <% if (targetUser.isEmailVerified) { %>
                        <span class="text-success"><i class="bi bi-check-circle-fill"></i> 已验证</span>
                      <% } else { %>
                        <span class="text-warning"><i class="bi bi-exclamation-circle-fill"></i> 未验证</span>
                      <% } %>
                    </div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">用户角色</div>
                    <div class="col-md-8">
                      <% if (targetUser.role === 'admin') { %>
                        <span class="badge bg-danger">管理员</span>
                      <% } else if (targetUser.role === 'moderator') { %>
                        <span class="badge bg-info">版主</span>
                      <% } else { %>
                        <span class="badge bg-secondary">普通用户</span>
                      <% } %>
                    </div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">账户状态</div>
                    <div class="col-md-8">
                      <% if (targetUser.isActive !== false) { %>
                        <span class="text-success"><i class="bi bi-check-circle-fill"></i> 正常</span>
                      <% } else { %>
                        <span class="text-danger"><i class="bi bi-x-circle-fill"></i> 已禁用</span>
                      <% } %>
                    </div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">双重认证</div>
                    <div class="col-md-8">
                      <% if (targetUser.twoFactorEnabled) { %>
                        <span class="badge bg-success">已启用</span>
                      <% } else { %>
                        <span class="badge bg-secondary">未启用</span>
                      <% } %>
                    </div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">注册时间</div>
                    <div class="col-md-8"><%= new Date(targetUser.createdAt).toLocaleString('zh-CN') %></div>
                  </div>
                  <div class="info-row row">
                    <div class="col-md-4 info-label">最后更新</div>
                    <div class="col-md-8"><%= new Date(targetUser.updatedAt).toLocaleString('zh-CN') %></div>
                  </div>
                </div>
              </div>
              
              <!-- 角色管理 -->
              <% if (targetUser.id !== user.id) { %>
                <div class="card mb-4">
                  <div class="card-header">
                    <h5 class="mb-0">角色管理</h5>
                  </div>
                  <div class="card-body">
                    <p class="text-muted">更改用户的角色权限：</p>
                    <div class="btn-group w-100">
                      <form method="POST" action="/admin/users/<%= targetUser.id %>/role" class="flex-fill">
                        <input type="hidden" name="role" value="user">
                        <button type="submit" class="btn btn-outline-secondary w-100 <%= targetUser.role === 'user' ? 'active' : '' %>">
                          普通用户
                        </button>
                      </form>
                      <form method="POST" action="/admin/users/<%= targetUser.id %>/role" class="flex-fill">
                        <input type="hidden" name="role" value="moderator">
                        <button type="submit" class="btn btn-outline-info w-100 <%= targetUser.role === 'moderator' ? 'active' : '' %>">
                          版主
                        </button>
                      </form>
                      <form method="POST" action="/admin/users/<%= targetUser.id %>/role" class="flex-fill">
                        <input type="hidden" name="role" value="admin">
                        <button type="submit" class="btn btn-outline-danger w-100 <%= targetUser.role === 'admin' ? 'active' : '' %>">
                          管理员
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              <% } %>
              
              <!-- 最近登录记录 -->
              <div class="card">
                <div class="card-header">
                  <h5 class="mb-0">最近登录记录</h5>
                </div>
                <div class="card-body p-0">
                  <div class="table-responsive">
                    <table class="table table-sm mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>时间</th>
                          <th>IP地址</th>
                          <th>状态</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% if (loginLogs.length === 0) { %>
                          <tr>
                            <td colspan="3" class="text-center py-3 text-muted">暂无登录记录</td>
                          </tr>
                        <% } else { %>
                          <% loginLogs.forEach(function(log) { %>
                            <tr>
                              <td><%= new Date(log.timestamp).toLocaleString('zh-CN') %></td>
                              <td><code><%= log.ip %></code></td>
                              <td>
                                <% if (log.success) { %>
                                  <span class="badge bg-success">成功</span>
                                <% } else { %>
                                  <span class="badge bg-danger">失败</span>
                                <% } %>
                              </td>
                            </tr>
                          <% }); %>
                        <% } %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
              
            </div>
          </div>
          
        </div>
      </div>
    </div>
  </div>
  
  <!-- 删除确认模态框 -->
  <div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">确认删除</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          确定要删除用户 <strong id="deleteUsername"></strong> 吗？此操作不可恢复！
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <form method="POST" action="" id="deleteForm" class="d-inline">
            <button type="submit" class="btn btn-danger">确认删除</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  
  <script>
    function confirmDelete(userId, username) {
      document.getElementById('deleteUsername').textContent = username;
      document.getElementById('deleteForm').action = '/admin/users/' + userId + '/delete';
      new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
  </script>
</body>
</html>
