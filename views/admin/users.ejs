<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('../partials/head') %>
  <style>
    .admin-sidebar {
      min-height: calc(100vh - 56px);
      background: #2c3e50;
      color: white;
    }
    .admin-sidebar .nav-link {
      color: rgba(255,255,255,0.8);
      padding: 12px 20px;
      border-left: 3px solid transparent;
    }
    .admin-sidebar .nav-link:hover,
    .admin-sidebar .nav-link.active {
      color: white;
      background: rgba(255,255,255,0.1);
      border-left-color: #3498db;
    }
    .admin-sidebar .nav-link i {
      width: 24px;
      margin-right: 8px;
    }
    .user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      object-fit: cover;
    }
    .role-badge-admin { background: #dc3545; }
    .role-badge-moderator { background: #0dcaf0; }
    .role-badge-user { background: #6c757d; }
    .status-active { color: #198754; }
    .status-inactive { color: #dc3545; }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container-fluid">
    <div class="row">
      <!-- 侧边栏 -->
      <div class="col-md-2 px-0">
        <div class="admin-sidebar py-3">
          <div class="px-4 mb-3">
            <h5 class="mb-0">管理后台</h5>
            <small class="text-muted">Admin Panel</small>
          </div>
          <nav class="nav flex-column">
            <a class="nav-link" href="/admin">
              <i class="bi bi-speedometer2"></i> 仪表盘
            </a>
            <a class="nav-link active" href="/admin/users">
              <i class="bi bi-people"></i> 用户管理
            </a>
            <a class="nav-link" href="/admin/stats">
              <i class="bi bi-graph-up"></i> 系统统计
            </a>
            <div class="mt-3 px-4">
              <small class="text-muted">返回</small>
            </div>
            <a class="nav-link" href="/dashboard">
              <i class="bi bi-arrow-left"></i> 用户中心
            </a>
          </nav>
        </div>
      </div>
      
      <!-- 主内容区 -->
      <div class="col-md-10 py-4">
        <div class="container-fluid">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">用户管理</h2>
            <span class="text-muted">共 <%= pagination.total %> 位用户</span>
          </div>
          
          <%- include('../partials/messages') %>
          
          <!-- 筛选栏 -->
          <div class="card mb-4">
            <div class="card-body">
              <form method="GET" action="/admin/users" class="row g-3">
                <div class="col-md-4">
                  <input type="text" name="search" class="form-control" 
                         placeholder="搜索用户名或邮箱" value="<%= filters.search %>">
                </div>
                <div class="col-md-2">
                  <select name="role" class="form-select">
                    <option value="">所有角色</option>
                    <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>管理员</option>
                    <option value="moderator" <%= filters.role === 'moderator' ? 'selected' : '' %>>版主</option>
                    <option value="user" <%= filters.role === 'user' ? 'selected' : '' %>>普通用户</option>
                  </select>
                </div>
                <div class="col-md-2">
                  <select name="isActive" class="form-select">
                    <option value="">所有状态</option>
                    <option value="true" <%= filters.isActive === true ? 'selected' : '' %>>正常</option>
                    <option value="false" <%= filters.isActive === false ? 'selected' : '' %>>已禁用</option>
                  </select>
                </div>
                <div class="col-md-2">
                  <select name="limit" class="form-select">
                    <option value="10" <%= pagination.limit === 10 ? 'selected' : '' %>>10条/页</option>
                    <option value="20" <%= pagination.limit === 20 ? 'selected' : '' %>>20条/页</option>
                    <option value="50" <%= pagination.limit === 50 ? 'selected' : '' %>>50条/页</option>
                  </select>
                </div>
                <div class="col-md-2">
                  <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> 筛选
                  </button>
                </div>
              </form>
            </div>
          </div>
          
          <!-- 用户列表 -->
          <div class="card">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>用户</th>
                      <th>角色</th>
                      <th>状态</th>
                      <th>注册时间</th>
                      <th>2FA</th>
                      <th>操作</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (users.length === 0) { %>
                      <tr>
                        <td colspan="6" class="text-center py-4 text-muted">暂无用户数据</td>
                      </tr>
                    <% } else { %>
                      <% users.forEach(function(targetUser) { %>
                        <tr>
                          <td>
                            <div class="d-flex align-items-center">
                              <img src="<%= targetUser.avatar || '/images/default-avatar.png' %>" 
                                   class="user-avatar me-3" alt="头像">
                              <div>
                                <div class="fw-bold"><%= targetUser.username %></div>
                                <small class="text-muted"><%= targetUser.email %></small>
                              </div>
                            </div>
                          </td>
                          <td>
                            <% if (targetUser.role === 'admin') { %>
                              <span class="badge role-badge-admin">管理员</span>
                            <% } else if (targetUser.role === 'moderator') { %>
                              <span class="badge role-badge-moderator">版主</span>
                            <% } else { %>
                              <span class="badge role-badge-user">用户</span>
                            <% } %>
                          </td>
                          <td>
                            <% if (targetUser.isActive !== false) { %>
                              <span class="status-active"><i class="bi bi-check-circle-fill"></i> 正常</span>
                            <% } else { %>
                              <span class="status-inactive"><i class="bi bi-x-circle-fill"></i> 已禁用</span>
                            <% } %>
                          </td>
                          <td>
                            <%= new Date(targetUser.createdAt).toLocaleDateString('zh-CN') %>
                          </td>
                          <td>
                            <% if (targetUser.twoFactorEnabled) { %>
                              <span class="badge bg-success">已启用</span>
                            <% } else { %>
                              <span class="badge bg-secondary">未启用</span>
                            <% } %>
                          </td>
                          <td>
                            <div class="btn-group btn-group-sm">
                              <a href="/admin/users/<%= targetUser.id %>" class="btn btn-outline-primary">
                                <i class="bi bi-eye"></i> 详情
                              </a>
                              
                              <% if (targetUser.id !== user.id) { %>
                                <!-- 角色切换 -->
                                <div class="btn-group">
                                  <button type="button" class="btn btn-outline-info dropdown-toggle" data-bs-toggle="dropdown">
                                    角色
                                  </button>
                                  <ul class="dropdown-menu">
                                    <li>
                                      <form method="POST" action="/admin/users/<%= targetUser.id %>/role" class="d-inline">
                                        <input type="hidden" name="role" value="user">
                                        <button type="submit" class="dropdown-item <%= targetUser.role === 'user' ? 'active' : '' %>">
                                          普通用户
                                        </button>
                                      </form>
                                    </li>
                                    <li>
                                      <form method="POST" action="/admin/users/<%= targetUser.id %>/role" class="d-inline">
                                        <input type="hidden" name="role" value="moderator">
                                        <button type="submit" class="dropdown-item <%= targetUser.role === 'moderator' ? 'active' : '' %>">
                                          版主
                                        </button>
                                      </form>
                                    </li>
                                    <li>
                                      <form method="POST" action="/admin/users/<%= targetUser.id %>/role" class="d-inline">
                                        <input type="hidden" name="role" value="admin">
                                        <button type="submit" class="dropdown-item <%= targetUser.role === 'admin' ? 'active' : '' %>">
                                          管理员
                                        </button>
                                      </form>
                                    </li>
                                  </ul>
                                </div>
                                
                                <!-- 禁用/启用 -->
                                <form method="POST" action="/admin/users/<%= targetUser.id %>/toggle-status" class="d-inline">
                                  <button type="submit" class="btn btn-outline-<%= targetUser.isActive !== false ? 'warning' : 'success' %>">
                                    <i class="bi bi-<%= targetUser.isActive !== false ? 'pause' : 'play' %>-fill"></i>
                                    <%= targetUser.isActive !== false ? '禁用' : '启用' %>
                                  </button>
                                </form>
                                
                                <!-- 删除 -->
                                <button type="button" class="btn btn-outline-danger" 
                                        onclick="confirmDelete('<%= targetUser.id %>', '<%= targetUser.username %>')">
                                  <i class="bi bi-trash"></i> 删除
                                </button>
                              <% } else { %>
                                <span class="badge bg-info">当前用户</span>
                              <% } %>
                            </div>
                          </td>
                        </tr>
                      <% }); %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          
          <!-- 分页 -->
          <% if (pagination.totalPages > 1) { %>
            <nav class="mt-4">
              <ul class="pagination justify-content-center">
                <% if (pagination.page > 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= pagination.page - 1 %>&search=<%= filters.search %>&role=<%= filters.role %>&isActive=<%= filters.isActive %>&limit=<%= pagination.limit %>">
                      上一页
                    </a>
                  </li>
                <% } %>
                
                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                  <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>&search=<%= filters.search %>&role=<%= filters.role %>&isActive=<%= filters.isActive %>&limit=<%= pagination.limit %>">
                      <%= i %>
                    </a>
                  </li>
                <% } %>
                
                <% if (pagination.page < pagination.totalPages) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= pagination.page + 1 %>&search=<%= filters.search %>&role=<%= filters.role %>&isActive=<%= filters.isActive %>&limit=<%= pagination.limit %>">
                      下一页
                    </a>
                  </li>
                <% } %>
              </ul>
            </nav>
          <% } %>
          
        </div>
      </div>
    </div>
  </div>
  
  <!-- 删除确认模态框 -->
  <div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">确认删除</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          确定要删除用户 <strong id="deleteUsername"></strong> 吗？此操作不可恢复！
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <form method="POST" action="" id="deleteForm" class="d-inline">
            <button type="submit" class="btn btn-danger">确认删除</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  
  <script>
    function confirmDelete(userId, username) {
      document.getElementById('deleteUsername').textContent = username;
      document.getElementById('deleteForm').action = '/admin/users/' + userId + '/delete';
      new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
  </script>
</body>
</html>
