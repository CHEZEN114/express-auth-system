<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('../partials/head') %>
  <style>
    .auth-container {
      max-width: 400px;
      margin: 3rem auto;
    }
    
    .auth-header {
      text-align: center;
      margin-bottom: 2rem;
      color: white;
    }
    
    .auth-header h1 {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
    
    .password-hint {
      font-size: 0.875rem;
      color: #666;
      margin-top: 0.25rem;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <main class="main-content">
    <div class="container">
      <div class="auth-container">
        <div class="auth-header">
          <h1>🆕 重置密码</h1>
          <p>设置您的新密码</p>
        </div>
        
        <div class="card">
          <%- include('../partials/messages') %>
          
          <form action="/reset-password" method="POST">
            <input type="hidden" name="token" value="<%= token %>">
            
            <div class="form-group">
              <label class="form-label" for="password">🔑 新密码</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                class="form-control" 
                placeholder="请输入新密码（至少6位）"
                minlength="6"
                required
              >
              <p class="password-hint">密码长度至少为6位</p>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="confirmPassword">🔐 确认新密码</label>
              <input 
                type="password" 
                id="confirmPassword" 
                name="confirmPassword" 
                class="form-control" 
                placeholder="请再次输入新密码"
                required
              >
            </div>
            
            <button type="submit" class="btn btn-primary btn-block">重置密码</button>
          </form>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
