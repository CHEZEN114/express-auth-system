<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('../partials/head') %>
  <style>
    .auth-container {
      max-width: 400px;
      margin: 3rem auto;
    }
    
    .auth-header {
      text-align: center;
      margin-bottom: 2rem;
      color: white;
    }
    
    .auth-header h1 {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
    
    .auth-footer {
      text-align: center;
      margin-top: 1.5rem;
      color: white;
    }
    
    .remember-me {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .remember-me input[type="checkbox"] {
      width: auto;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <main class="main-content">
    <div class="container">
      <div class="auth-container">
        <div class="auth-header">
          <h1>🔐 欢迎回来</h1>
          <p>登录您的账户</p>
        </div>
        
        <div class="card">
          <%- include('../partials/messages') %>
          
          <form action="/login" method="POST">
            <div class="form-group">
              <label class="form-label" for="email">📧 邮箱地址</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                class="form-control" 
                placeholder="请输入邮箱"
                required
              >
            </div>
            
            <div class="form-group">
              <label class="form-label" for="password">🔑 密码</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                class="form-control" 
                placeholder="请输入密码"
                required
              >
            </div>
            
            <div class="form-group">
              <label class="remember-me">
                <input type="checkbox" name="remember" value="true">
                <span>记住我（7天）</span>
              </label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-block">登录</button>
          </form>
          
          <div style="text-align: center; margin-top: 1.5rem;">
            <a href="/forgot-password" class="text-link">忘记密码？</a>
          </div>
        </div>
        
        <div class="auth-footer">
          <p>还没有账户？<a href="/register" class="text-link" style="color: white; text-decoration: underline;">立即注册</a></p>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
