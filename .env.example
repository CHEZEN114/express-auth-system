# 复制此文件为 .env 并填写实际值

# ============================================
# 基础配置
# ============================================

# Session 密钥（用于加密 Session）
# 建议生成随机字符串：openssl rand -base64 32
SESSION_SECRET=your-super-secret-key-change-this-in-production

# 服务器端口
PORT=3000

# Node 环境
NODE_ENV=development

# ============================================
# 邮件服务配置
# ============================================

# 邮件服务提供商: smtp, sendgrid, console (开发环境使用 console)
EMAIL_PROVIDER=console

# 发件人信息
EMAIL_FROM_NAME=用户认证系统
EMAIL_FROM_ADDRESS=noreply@example.com

# SMTP 配置（使用 EMAIL_PROVIDER=smtp 时生效）
# 常见 SMTP 服务:
# Gmail: smtp.gmail.com:587
# QQ邮箱: smtp.qq.com:465
# 163邮箱: smtp.163.com:465
# Outlook: smtp.office365.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid 配置（使用 EMAIL_PROVIDER=sendgrid 时生效）
# SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================
# OAuth 配置（可选）
# ============================================

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# 数据库配置（后续 Phase 使用）
# ============================================

# MongoDB 连接字符串（Phase 5 使用）
# MONGODB_URI=mongodb://localhost:27017/express-auth

# Redis 配置（Phase 6 使用）
# REDIS_URL=redis://localhost:6379
